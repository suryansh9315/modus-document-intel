# ─────────────────────────────────────────────────────────────
# Modus Document Intelligence — Environment Variables
# Copy to .env and fill in the values
#
# Local dev (full stack):  docker compose -f infra/docker-compose.local.yml up
# Production (api only):   docker compose -f infra/docker-compose.yml up -d
#   → Set MONGO_URI to your Atlas connection string for production
# ─────────────────────────────────────────────────────────────

# Required: Cerebras API key (get one at https://cloud.cerebras.ai)
CEREBRAS_API_KEY=csk_your_key_here

# MongoDB connection URI
# Local dev:   mongodb://localhost:27017
# docker-compose.local.yml: mongodb://mongo:27017  (overridden automatically)
# Production (Atlas): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/modus_db
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=modus_db

# DuckDB file path
DUCKDB_PATH=/data/modus.duckdb

# Upload directory for PDF files
UPLOAD_DIR=/data/uploads

# Frontend API URL — used by the browser (client-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL — used by Next.js API routes inside Docker
# Local dev: http://localhost:8000
# docker-compose: http://api:8000  (set automatically by docker-compose)
API_URL=http://localhost:8000

# CORS origins — comma-separated list of allowed origins
# Production: set to your Vercel deployment URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# LangSmith tracing — view all LangGraph node executions at smith.langchain.com
# Optional: leave blank to disable tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_PROJECT=modus
