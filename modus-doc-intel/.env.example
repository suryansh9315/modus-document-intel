# ─────────────────────────────────────────────────────────────
# Modus Document Intelligence — Environment Variables
# Copy to .env and fill in the values
# ─────────────────────────────────────────────────────────────

# Required: Groq API key (get one at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# MongoDB connection URI (default works with docker-compose)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=modus_db

# DuckDB file path (default works with docker-compose)
DUCKDB_PATH=/data/modus.duckdb

# Upload directory for PDF files
UPLOAD_DIR=/data/uploads

# Prefect API URL (for Prefect flow deployment)
PREFECT_API_URL=http://127.0.0.1:4200/api

# Frontend API URL (baked in at Next.js build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# LangSmith tracing — view all LangGraph node executions at smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=modus-doc-intel
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
